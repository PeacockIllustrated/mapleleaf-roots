{
  "name": "mapleleaf-roots",
  "version": "0.1.0",
  "private": true,
  "description": "Franchise operations platform for Mapleleaf Petroleum Group",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,md,sql}\"",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:types": "supabase gen types typescript --local > lib/supabase/database.types.ts",
    "seed:verify": "tsx scripts/verify-seed.ts"
  },
  "dependencies": {
    "@fontsource/poppins": "^5.1.0",
    "@hookform/resolvers": "^3.9.0",
    "@react-pdf/renderer": "^4.0.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.0",
    "@tanstack/react-table": "^8.20.5",
    "clsx": "^2.1.1",
    "immer": "^10.1.1",
    "konva": "^9.3.0",
    "lucide-react": "^0.454.0",
    "next": "^15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.0",
    "react-konva": "^19.0.0",
    "resend": "^4.0.0",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "^15.0.3",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "supabase": "^1.219.0",
    "tailwindcss": "^4.0.0-beta.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.12.3"
}
