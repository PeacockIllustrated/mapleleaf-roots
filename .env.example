# ============================================================================
# Mapleleaf Roots — Environment variables
# ============================================================================
# Copy this file to .env.local and fill in the values below.
# NEVER commit .env.local. It's in .gitignore already.
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase
# ----------------------------------------------------------------------------
# Public values — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER expose to the browser, only used in Server Actions and API routes
SUPABASE_SERVICE_ROLE_KEY=

# Supabase project reference (used by the CLI for linked migrations)
SUPABASE_PROJECT_REF=

# ----------------------------------------------------------------------------
# Resend (transactional email)
# ----------------------------------------------------------------------------
# Optional for Phase 1. Required for invite emails and rollout notifications in Phase 2+.
RESEND_API_KEY=
RESEND_FROM_EMAIL=roots@mapleleafpetroleum.com

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
# Public URL of the app — used for magic-link redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Onesign integration (Phase 2+)
# ----------------------------------------------------------------------------
# When the Onesign Portal exposes a webhook for quote acknowledgement, these
# credentials will authenticate the bridge. Leave blank for Phase 1.
ONESIGN_PORTAL_WEBHOOK_URL=
ONESIGN_PORTAL_WEBHOOK_SECRET=
